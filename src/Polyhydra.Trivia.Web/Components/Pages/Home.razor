@page "/"

<PageTitle>Polyhydra Trivia</PageTitle>

<section class="page-header">
    <h1>Polyhydra Trivia</h1>
    <p>Browse topics, play a question, and show stream-friendly poll results from the Trivia API.</p>
</section>

<div class="action-grid">
    <a class="action-card" href="/topics">
        <span>Browse topics</span>
        <strong>Review curated learning areas and their questions.</strong>
    </a>
    <a class="action-card" href="/play">
        <span>Play trivia</span>
        <strong>Start a web poll, vote, lock results, and reveal the answer.</strong>
    </a>
    <a class="action-card" href="/admin/topics">
        <span>Manage content</span>
        <strong>Create topics and draft questions through the web app.</strong>
    </a>
</div>
